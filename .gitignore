# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# PyTorch checkpoints — large binary files; keep only via .gitkeep
checkpoints/*.npz
checkpoints/*.pt
checkpoints/*.pth
!checkpoints/.gitkeep

# Dataset — never commit raw data
archive/

# GPU slot lock files (runtime artefacts)
gpu_locks/*.lock
!gpu_locks/.gitkeep

# HuggingFace / torch model cache
.cache/
~/.cache/

# Environment variables / secrets
.env
.env.*

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.log
